# ---- Environment Variables Reference -------------------------------------
# Copy to .env and fill in your values.
# Variables marked [REQUIRED] must be set for production.
# Variables marked [OPTIONAL] enable additional features.

# ============================================================================
# Core API
# ============================================================================

# [REQUIRED in prod] PostgreSQL connection (falls back to JSON storage if unset)
DATABASE_URL=postgresql+asyncpg://mushroom:yourpassword@localhost:5432/mushroom_cloud
DB_ECHO=false

# [OPTIONAL] Environment identifier
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================================
# Authentication
# ============================================================================

# [REQUIRED in prod] Clerk authentication
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# [OPTIONAL] Legacy JWT fallback auth (dev only)
JWT_SECRET=dev-secret-change-in-production

# ============================================================================
# Frontend (set in frontend/.env.local)
# ============================================================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ============================================================================
# Security
# ============================================================================

# [REQUIRED in prod] CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Upload Limits (20GB default)
MAX_UPLOAD_SIZE_BYTES=21474836480

# Session
SESSION_TIMEOUT_MINUTES=480

# [REQUIRED in prod] Encryption key for at-rest encryption
ENCRYPTION_KEY=your-256-bit-key-here

# ============================================================================
# LLM Providers
# ============================================================================

# [REQUIRED] At least one LLM provider key
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ============================================================================
# Error Tracking (Sentry)
# ============================================================================

# [OPTIONAL] Sentry DSN — leave blank to disable
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# Cloud Backup
# ============================================================================

# [OPTIONAL] Backblaze B2
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# [OPTIONAL] Dropbox (auto-detected via desktop app, no key needed)

# ============================================================================
# Integrations
# ============================================================================

# [OPTIONAL] Google OAuth + Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [OPTIONAL] E-Signature (Dropbox Sign / HelloSign)
DROPBOX_SIGN_API_KEY=

# [OPTIONAL] Email notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ============================================================================
# Docker Production
# ============================================================================

# Database password (used in docker-compose.prod.yml)
DB_PASSWORD=change-me-in-production

# Domain for SSL/nginx
DOMAIN=your-domain.com
