# ---- Environment Variables Reference -------------------------------------
# Copy to .env and fill in your values.

# Required
DATABASE_URL=postgresql+asyncpg://mushroom:yourpassword@localhost:5432/mushroom_cloud
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# Frontend (set in frontend/.env.local)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS — comma-separated (lock down in production!)
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Upload Limits (20GB)
MAX_UPLOAD_SIZE_BYTES=21474836480

# Session
SESSION_TIMEOUT_MINUTES=480

# Encryption (REQUIRED in production)
ENCRYPTION_KEY=your-256-bit-key-here

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Integrations (optional)
DROPBOX_ACCESS_TOKEN=
BACKBLAZE_KEY_ID=
BACKBLAZE_APPLICATION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DROPBOX_SIGN_API_KEY=

# Docker (production)
DB_PASSWORD=change-me-in-production
