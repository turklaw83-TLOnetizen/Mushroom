# ---- Project Mushroom Cloud — Production Environment ----------------------
# Deployment for: Turklay Law (app.turklaylaw.com)
# Generated: 2026-03-01
#
# INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.production .env
# 2. Fill in ALL values marked FILL_ME
# 3. Run: docker compose -f docker-compose.prod.yml up -d

# ---- Database ----
DB_PASSWORD=FILL_ME                   # Generate: openssl rand -base64 32
DATABASE_URL=postgresql+asyncpg://mushroom:${DB_PASSWORD}@db:5432/mushroom_cloud

# ---- Authentication (Clerk) ----
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=FILL_ME              # sk_live_xxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=FILL_ME   # pk_live_xxxxx
CLERK_JWKS_URL=FILL_ME               # https://YOUR_CLERK_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# Legacy JWT (still needed for internal service-to-service calls)
JWT_SECRET=FILL_ME                    # Generate: openssl rand -base64 48

# ---- Domain & CORS ----
ENVIRONMENT=production
DOMAIN=app.turklaylaw.com
CORS_ORIGINS=https://app.turklaylaw.com
NEXT_PUBLIC_API_URL=https://app.turklaylaw.com/api

# ---- Clerk Frontend URLs ----
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ---- LLM API Keys (at least one required) ----
ANTHROPIC_API_KEY=FILL_ME             # Required for Claude analysis
XAI_API_KEY=                          # Optional: Grok fallback
# OPENAI_API_KEY=                     # Optional
# GOOGLE_API_KEY=                     # Optional

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# ---- File Upload ----
MAX_UPLOAD_SIZE_BYTES=21474836480     # 20 GB

# ---- Error Tracking (optional but recommended) ----
# SENTRY_DSN=                         # Get from sentry.io
# NEXT_PUBLIC_SENTRY_DSN=             # Same DSN for frontend

# ---- Monitoring ----
GRAFANA_ADMIN_PASSWORD=FILL_ME        # Generate: openssl rand -base64 16

# ---- Cloud Backup (optional) ----
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=

# ---- Encryption (optional — enables at-rest encryption for case data) ----
# ENCRYPTION_KEY=                     # Generate: openssl rand -hex 32
