# ---- Project Mushroom Cloud — Production Environment Variables -----------
# Copy this file to .env and fill in all required values before deploying.
#
# REQUIRED values are marked. Everything else has sensible defaults.

# ---- Database (REQUIRED) ----
DB_PASSWORD=                          # Strong password for PostgreSQL
DATABASE_URL=postgresql+asyncpg://mushroom:${DB_PASSWORD}@db:5432/mushroom_cloud

# ---- Authentication (REQUIRED) ----
JWT_SECRET=                           # 32+ character random string for JWT signing
CLERK_SECRET_KEY=                     # Clerk backend secret key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=    # Clerk frontend publishable key

# ---- LLM API Keys (at least one REQUIRED) ----
ANTHROPIC_API_KEY=                    # Claude API key
XAI_API_KEY=                          # Grok API key (fallback provider)
# OPENAI_API_KEY=                     # Optional: OpenAI API key
# GOOGLE_API_KEY=                     # Optional: Google/Gemini API key

# ---- Deployment ----
ENVIRONMENT=production
CORS_ORIGINS=https://yourdomain.com   # Comma-separated allowed origins
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS=120               # Max requests per window
RATE_LIMIT_WINDOW_SECONDS=60          # Window duration

# ---- File Upload ----
MAX_UPLOAD_SIZE_BYTES=21474836480     # 20 GB

# ---- Error Tracking (optional) ----
# SENTRY_DSN=                         # Sentry DSN for error reporting

# ---- Monitoring (optional) ----
GRAFANA_ADMIN_PASSWORD=admin          # Grafana dashboard password

# ---- Cloud Backup (optional) ----
# B2_APPLICATION_KEY_ID=              # Backblaze B2 key ID
# B2_APPLICATION_KEY=                 # Backblaze B2 application key
# B2_BUCKET_NAME=                     # Backblaze B2 bucket name

# ---- Profiling (optional, dev/staging only) ----
# ENABLE_PROFILING=false
# DB_ECHO=false
